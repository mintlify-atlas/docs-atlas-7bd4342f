{
  "$schema": "https://mintlify.com/docs.json",
  "name": "GitHub Training Kit",
  "theme": "linden",
  "colors": {
    "primary": "#24292f",
    "light": "#6e7781",
    "dark": "#0d1117"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/github/training-kit"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/github/training-kit"
    }
  },
  "navigation": {
