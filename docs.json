            ]
          },
          {
            "group": "Git Guides",
            "pages": [
              "guides/git-overview",
              "guides/install-git",
              "guides/git-init",
              "guides/git-clone",
              "guides/git-add",
              "guides/git-commit",
              "guides/git-status",
              "guides/git-push",
              "guides/git-pull",
              "guides/git-remote"
            ]
          },
          {
            "group": "Advanced Topics",
            "pages": [
              "advanced/submodules-vs-subtrees",
              "advanced/svn-migration",
              "advanced/git-concepts"
            ]
          }
        ]
      },
      {
        "tab": "Cheat Sheets",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "cheatsheets/git-cheatsheet",
